# Secrets do Kamal. Source via shell — variáveis disponíveis aqui podem
# referenciar env vars exportadas, comandos shell, ou arquivos.
#
# IMPORTANTE: este arquivo É commitado no git, MAS não contém nenhum valor
# literal de segredo — só referências a env vars (que vêm do CI no GHA, ou
# de ~/.config/controle-financeiro/secrets.env quando rodando local) e
# `cat config/master.key` (gitignored, só existe localmente). Não escrever
# nenhum secret direto aqui.

# Source do ambiente local (carrega DSNs, senhas DB, GHCR token).
if [ -f ~/.config/controle-financeiro/secrets.env ]; then
  set -a
  source ~/.config/controle-financeiro/secrets.env
  set +a
fi

# Rails master key (decripta credentials.yml.enc).
RAILS_MASTER_KEY=$(cat config/master.key)

# GHCR token (write:packages) — vem do shell env.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Sentry DSN do backend.
SENTRY_DSN=$SENTRY_DSN_BACKEND

# Database password — lida diretamente do secrets/.env gerado pelo `newapp`
# na oracle-app-box (~/apps/controle-financeiro/secrets/.env).
# O mesmo role `portilho` é usado em staging e production — só o DB name muda.
# Formato do arquivo: DATABASE_URL=postgres://portilho:<SENHA>@host.docker.internal:5432/...
DATABASE_PASSWORD=$(ssh oracle-app-box "cut -d: -f5 ~/.pgpass")
